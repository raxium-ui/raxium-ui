@@ -96,6 +96,16 @@ var layerStack = {
     layer.styleTargets?.forEach((getTarget) => {
       const target = getTarget();
       if (target) {
+        // PATCH: freeze the resolved z-index before clearing the layer CSS vars.
+        // remove() runs on close-start (effect cleanup) while the layer node may still
+        // be mounted and playing its exit animation. Clearing --layer-index collapses
+        // the layer's z-index to the base band, so still-open lower layers with a higher
+        // --layer-index paint over it and hide the exit animation. Pinning the current
+        // computed z-index keeps its stacking order until it unmounts.
+        const { zIndex } = (0, import_dom_query.getComputedStyle)(target);
+        if (zIndex && zIndex !== "auto") {
+          target.style.setProperty("z-index", zIndex);
+        }
         clearLayerStyleMirror(target);
       }
     });
@@ -118,6 +128,9 @@ var layerStack = {
       layer.styleTargets?.forEach((getTarget) => {
         const target = getTarget();
         if (!target || target === layer.node) return;
+        // PATCH: clear any frozen exit z-index so a reused/re-activated layer
+        // resumes class-based stacking (see freeze in remove()).
+        target.style.removeProperty("z-index");
         applyLayerStackMetadata(layer, index, target);
         const { zIndex } = (0, import_dom_query.getComputedStyle)(layer.node);
         target.style.setProperty("--z-index", zIndex);
