{
  "name": "@raxium/mcp-apis",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "description": "Bun + Fastify API server for Raxium MCP-compatible endpoints",
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "start:pm2": "pm2 start ecosystem.config.cjs",
    "stop:pm2": "pm2 stop raxium-mcp-apis",
    "restart:pm2": "pm2 restart raxium-mcp-apis",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "fastify": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
