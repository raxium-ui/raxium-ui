{
  "name": "@raxium/vue-addons-u-murri",
  "version": "0.1.0",
  "packageManager": "pnpm@10.13.1",
  "description": "Murri composable for Raxium UI",
  "author": {
    "name": "Hwacc",
    "email": "mshcccck@gmail.com",
    "url": "https://github.com/raxium-ui/raxium-ui"
  },
  "license": "MIT",
  "keywords": [
    "raxium",
    "raxium-ui",
    "vue",
    "addons",
    "murri"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./index.css": "./dist/index.css"
  },
  "module": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "copy:css": "bun -e \"import { mkdir } from 'node:fs/promises'; await mkdir('./dist', { recursive: true }); await Bun.write('./dist/index.css', Bun.file('./src/index.css'));\"",
    "build": "tsc --project tsconfig.build.json && bun run copy:css",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "peerDependencies": {
    "vue": "^3.5.27"
  },
  "dependencies": {
    "@vueuse/core": "^14.1.0",
    "es-toolkit": "^1.44.0",
    "muuri": "^0.9.5"
  }
}
