{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.addons.swiper",
  "component": {
    "name": "Swiper",
    "framework": "vue",
    "package": "@raxium/vue-addons-swiper",
    "importPath": "@raxium/vue-addons-swiper",
    "exportName": "Swiper",
    "category": "addon",
    "description": "addons 中的轮播组件集合，面向轮播容器、分页器、导航按钮和滚动条等常见组合场景。基于 swiper 生态二次封装，核心能力以底层库为主，补充 SwiperPagination 的 autoplay-bullets 扩展类型。由 Swiper、SwiperSlide、SwiperPagination、SwiperNavigationPrev/Next、SwiperScrollbar、SwiperPrev/Next 组合而成。当前不提供 theme 与 ui 配置，支持 class、data-part 与 CSS 变量样式扩展。",
    "basePrimitive": {
      "library": "swiper/vue",
      "primitive": "Swiper",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": ["aria-*", "data-*", "class"],
      "notes": "SwiperProps 继承 SwiperOptions 全部透传；SwiperNavigation*、SwiperPagination、SwiperScrollbar 部分透传对应模块参数，enabled/el 由组件内部接管。"
    },
    "capabilities": [
      "carousel",
      "pagination",
      "navigation",
      "scrollbar",
      "autoplay",
      "loop",
      "slot-composition"
    ],
    "subComponents": [
      "SwiperSlide",
      "SwiperPagination",
      "SwiperNavigationPrev",
      "SwiperNavigationNext",
      "SwiperScrollbar",
      "SwiperPrev",
      "SwiperNext"
    ]
  },
