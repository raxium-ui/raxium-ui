  "generationHints": {
    "preferredUsageOrder": [
      "modules",
      "direction",
      "SwiperSlide",
      "SwiperPagination",
      "SwiperNavigationPrev/Next"
    ],
    "safeDefaults": {
      "tag": "div",
      "wrapperTag": "div",
      "direction": "horizontal"
    },
    "a11yChecklist": [
      "轮播区域需提供 role=\"region\" 与 aria-roledescription=\"carousel\"（组件已内置）。",
      "导航与分页按钮需具备可聚焦与键盘可操作。"
    ],
    "codegenTemplates": {
      "minimal": "<Swiper>\n  <SwiperSlide v-for=\"i in 5\" :key=\"i\">Slide {{ i }}</SwiperSlide>\n</Swiper>",
      "withPagination": "<Swiper :modules=\"[Pagination]\">\n  <SwiperSlide v-for=\"i in 5\" :key=\"i\">Slide {{ i }}</SwiperSlide>\n  <template #container-end>\n    <SwiperPagination />\n  </template>\n</Swiper>",
      "withNavigation": "<Swiper :modules=\"[Navigation]\">\n  <SwiperSlide v-for=\"i in 5\" :key=\"i\">Slide {{ i }}</SwiperSlide>\n  <template #container-end>\n    <SwiperNavigationPrev /><SwiperNavigationNext />\n  </template>\n</Swiper>"
    },
    "antiPatterns": [
      "使用 Swiper 组件但未引入 index.css — 导致 swiper 基础样式与 rui-swiper-* 结构类缺失，轮播布局错乱",
      "<SwiperPagination /> — 未将 Pagination 模块加入 Swiper.modules，分页不生效",
      "<Swiper><SwiperNavigationPrev /></Swiper> — 导航组件未放在 container-start/container-end 插槽内，建议放于插槽以便定位统一"
    ]
  },
