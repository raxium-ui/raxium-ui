      "notes": "根组件透传 Ark UI Root 常用参数与状态机能力（open/defaultOpen、尺寸、位置、lazyMount/unmountOnExit 等）。"
    },
    "capabilities": [
      "theme",
      "draggable",
      "resizable",
      "stage",
      "opacity",
      "pinned",
      "open",
      "lazyMount",
      "unmountOnExit"
