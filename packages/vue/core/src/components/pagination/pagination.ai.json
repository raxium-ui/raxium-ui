        "aria-*",
        "data-*"
      ],
      "notes": "透传 Ark UI PaginationRootBaseProps；theme、ui 为 Rark 扩展。"
    },
    "capabilities": [
      "v-model:page",
      "v-model:page-size",
      "theme",
      "ui-override",
      "programmatic-api"
    ],
    "subComponents": ["PaginationGoTo", "PaginationGoToTrigger", "PaginationPageSize"]
