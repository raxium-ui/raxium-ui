  "behaviorModel": {
    "stateVars": {
      "page": "number",
      "pageSize": "number",
      "pages": "Array<{ type: 'page' | 'ellipsis'; value?: number }>"
    },
    "derived": {
      "totalPages": "Math.ceil(count / pageSize)",
      "canGoPrev": "page > 1",
      "canGoNext": "page < totalPages"
    },
    "transitions": [
      {
        "on": "goToFirstPage",
        "guard": "page > 1",
        "effects": ["setPage(1)", "emit:update:page"]
      },
      {
        "on": "goToLastPage",
        "guard": "page < totalPages",
        "effects": ["setPage(totalPages)", "emit:update:page"]
      },
      {
        "on": "prevPage",
        "guard": "canGoPrev",
        "effects": ["setPage(page - 1)", "emit:update:page"]
      },
      {
        "on": "nextPage",
        "guard": "canGoNext",
        "effects": ["setPage(page + 1)", "emit:update:page"]
      }
    ]
  },
