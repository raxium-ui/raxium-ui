{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.date-picker",
  "component": {
    "name": "DatePicker",
    "framework": "vue",
    "package": "@raxium/vue/core",
    "importPath": "@raxium/vue/core",
    "exportName": "DatePicker",
    "category": "core",
    "description": "用于单日期与日期范围选择的复合组件，支持日/月/年多视图切换、受控状态管理、禁用日期规则与事件监听。基于 Ark UI useDatePicker 与 DatePicker.RootProvider 封装，在 Raxium UI 中扩展 theme 主题能力与 tvDatePicker crafts 覆盖，适用于表单录入、筛选面板与时间范围查询场景。",
    "basePrimitive": {
      "library": "@ark-ui/vue",
      "primitive": "DatePicker.RootProvider",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": [
        "id",
        "disabled",
        "aria-*",
        "data-*"
      ],
      "notes": "根组件透传 DatePickerRootBaseProps；子组件 DatePickerControl、DatePickerContent、DatePicker*View 透传 Ark 子原语属性。"
    },
    "capabilities": [
      "single-date",
      "range-date",
      "multi-view",
      "controlled",
      "uncontrolled",
      "theme",
      "disabled-date",
      "slot-composition"
    ],
    "subComponents": [
      "DatePickerControl",
      "DatePickerContent",
      "DatePickerDayView",
      "DatePickerMonthView",
      "DatePickerYearView"
    ]
  },
