  "behaviorModel": {
    "stateVars": {
      "modelValue": "DateValue[] | undefined",
      "open": "boolean | undefined",
      "view": "'day' | 'month' | 'year' | undefined",
      "focusedValue": "DateValue | undefined",
      "selectionMode": "'single' | 'range' | 'multiple'"
    },
    "derived": {
      "isOpen": "open === true",
      "hasValue": "modelValue?.length > 0",
      "isRangeMode": "selectionMode === 'range'"
    },
    "transitions": [
      {
        "on": "valueChange",
        "guard": "!disabled",
        "effects": ["emit:update:modelValue", "emit:valueChange"]
      },
      {
        "on": "openChange",
        "guard": "always",
        "effects": ["emit:update:open", "emit:openChange"]
      },
      {
        "on": "viewChange",
        "guard": "always",
        "effects": ["emit:update:view", "emit:viewChange"]
      },
      {
        "on": "focusChange",
        "guard": "always",
        "effects": ["emit:update:focusedValue", "emit:focusChange"]
      }
    ]
  },
