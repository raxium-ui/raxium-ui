        "aria-*",
        "data-*"
      ],
      "notes": "透传 Ark UI SliderRootBaseProps；theme、ui 为 Rark 扩展。"
    },
    "capabilities": [
      "v-model",
      "theme",
      "ui-override",
      "programmatic-api"
