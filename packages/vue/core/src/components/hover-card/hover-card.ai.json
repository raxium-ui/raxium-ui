      "withArrow": "<HoverCard>\n  <HoverCardTrigger asChild><Button>Hover</Button></HoverCardTrigger>\n  <HoverCardContent>\n    <HoverCardArrow />\n    Content\n  </HoverCardContent>\n</HoverCard>"
    },
