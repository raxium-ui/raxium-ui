  "behaviorModel": {
    "stateVars": {
      "type": "info | success | warning | error | loading",
      "placement": "string"
    },
    "derived": {
      "showCloseIcon": "type !== 'loading'",
      "iconVNode": "switch(type): info->Info, success->CircleCheck, error->CircleX, warning->CircleAlert, loading->LoaderCircle"
    },
    "transitions": [
      {
        "on": "options.render",
        "guard": "typeof options?.render === 'function'",
        "effects": [
          "contentNode = options.render(context)",
          "slots.default.bypassed = true",
          "slots.icon.bypassed = true",
          "slots.inner.bypassed = true",
          "slots.close.bypassed = true"
        ]
      },
      {
        "on": "default",
        "guard": "typeof options?.render !== 'function'",
        "effects": [
          "renderIcon(type)",
          "renderInner(options.title, options.description)",
          "renderClose(type !== 'loading')"
        ]
      }
    ]
  },
