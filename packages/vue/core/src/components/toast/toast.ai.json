  "generationHints": {
    "preferredUsageOrder": [
      "useToast().toast.create/success/error/info/warning/loading",
      "ToasterManager + Toaster + Toast",
      "options.type + options.title + options.description"
    ],
    "safeDefaults": {
      "ToasterManager.disableDefaultToaster": false,
      "options": "必填"
    },
    "a11yChecklist": [
      "duration: Infinity 时应提供可见关闭入口",
      "关键流程建议使用 title + description 双层信息",
      "多位置容器并存时保持统一 placement 策略"
    ],
    "codegenTemplates": {
      "minimal": "<ToasterManager />\n// 在子组件中: const { toast } = useToast(); toast.create({ title: '提示', type: 'info' })",
      "withToasterManager": "<ToasterManager><Toaster v-slot=\"{ toast }\"><Toast :options=\"toast\" /></Toaster></ToasterManager>",
      "useToastCreate": "const { toast } = useToast(); toast.create({ title: '提示', type: 'info' })",
      "useToastSuccess": "const { toast } = useToast(); toast.success({ title: '成功', description: '操作已完成' })",
      "multiPlacement": "<ToasterManager :disable-default-toaster=\"true\"><Toaster v-slot=\"{ toast }\" toaster-id=\"top-end\" placement=\"top-end\" overlap><Toast :options=\"toast\" /></Toaster><Toaster v-slot=\"{ toast }\" toaster-id=\"bottom-start\" placement=\"bottom-start\" overlap><Toast :options=\"toast\" /></Toaster></ToasterManager>"
    },
    "antiPatterns": [
      "const { toast } = useToast(); toast.create({ type: 'error' })",
      "const { toast } = useToast(); toast.create({})",
      "<div><Button @click=\"() => useToast().toast.create({ title: 'x' })\" /></div>"
    ]
  },
