      "library": "@ark-ui/vue/tooltip",
      "primitive": "Tooltip.RootProvider",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": [
        "aria-*",
        "data-*"
      ],
      "notes": "透传 Ark UI TooltipRootBaseProps；theme 为 Rark 扩展。TooltipContent、TooltipArrow 提供 ui 覆盖。"
    },
    "capabilities": [
      "v-model:open",
      "theme",
      "ui-override",
      "positioning"
    ],
    "subComponents": ["TooltipTrigger", "TooltipContent", "TooltipArrow"]
  },
