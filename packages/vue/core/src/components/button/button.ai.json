{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.button",
  "component": {
    "name": "Button",
    "framework": "vue",
    "package": "@raxium/vue/core",
    "importPath": "@raxium/vue/core",
    "exportName": "Button",
    "category": "core",
    "description": "用于触发操作、提交表单或承载快捷动作的基础交互组件。基于 Ark UI 的 ark.button 原语封装，通过 tvButton 提供 variant 与 color 语义组合、尺寸与加载态，支持水波纹反馈，并扩展 theme 与 ui 配置能力。",
    "basePrimitive": {
      "library": "@ark-ui/vue/factory",
      "primitive": "ark.button",
      "nativeElement": "button"
    },
    "passThrough": {
      "htmlAttributes": [
        "type",
        "disabled",
        "aria-*",
        "data-*"
      ],
      "notes": "组件基于 factory 原语封装，不是 Ark UI 独立业务组件。"
    },
    "capabilities": [
      "click",
      "loading",
      "ripple",
      "theme",
      "ui-override",
      "as-child",
      "variant-color"
    ]
  },
  "contracts": {
    "props": [
      {
        "name": "variant",
        "required": false,
        "requiredSource": "type",
        "typeText": "'solid' | 'outlined' | 'filled' | 'text' | 'link' | 'icon' | string",
        "typeSchema": {
          "anyOf": [
            {
              "enum": [
                "solid",
                "outlined",
                "filled",
                "text",
                "link",
                "icon"
              ]
            },
            {
              "type": "string"
            }
          ]
        },
        "default": "solid",
        "defaultKind": "explicit-runtime",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "按钮形态变体；icon 为方形图标按钮（由 tvButton compoundVariants 等驱动）。"
      },
      {
        "name": "color",
        "required": false,
        "requiredSource": "type",
        "typeText": "'primary' | 'default' | 'danger' | 'warning' | 'info' | string",
        "typeSchema": {
          "anyOf": [
            {
              "enum": [
                "primary",
                "default",
                "danger",
                "warning",
                "info"
              ]
            },
            {
              "type": "string"
            }
          ]
        },
        "default": "primary",
        "defaultKind": "explicit-runtime",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "语义色，与根节点 data-color 及主题 CSS 配合；与 theme.surface（亮/暗表面）含义不同。"
      },
      {
        "name": "disabled",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": {
          "type": "boolean"
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "是否禁用按钮交互（同时阻断 ripple）。"
      },
      {
        "name": "ripple",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": {
          "type": "boolean"
        },
        "default": false,
        "defaultKind": "explicit-runtime",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "是否启用点击水波纹效果。"
      },
      {
        "name": "loading",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": {
          "type": "boolean"
        },
        "default": false,
        "defaultKind": "explicit-runtime",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "是否显示加载图标，可由 loading 插槽覆盖。"
      },
      {
        "name": "asChild",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": {
          "type": "boolean"
        },
        "default": false,
        "defaultKind": "explicit-runtime",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "是否将 props 合并到子元素（复合组件场景）。"
      },
      {
        "name": "tooltip",
        "required": false,
        "requiredSource": "type",
        "typeText": "string",
        "typeSchema": {
          "type": "string"
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "提示文案字段（用于上层组合；当前组件模板未直接渲染 tooltip）。"
      },
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | array | object",
        "typeSchema": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "array"
            },
            {
              "type": "object"
            }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根节点自定义 class。"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ThemeCrafts<'tvButton'>（含 theme.size/skin/surface 等与 tvButton 变体合并）",
        "typeSchema": {
          "type": "object"
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "主题配置，驱动 tvButton crafts；展开传入 crafts.root/loading 的 ...theme。"
      },
      {
        "name": "ui",
        "required": false,
        "requiredSource": "type",
        "typeText": "{ root?: { class?: string | array | object }, loading?: { class?: string | array | object } }",
        "typeSchema": {
          "type": "object",
          "properties": {
            "root": {
              "type": "object",
              "properties": {
                "class": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "array"
                    },
                    {
                      "type": "object"
                    }
                  ]
                }
              },
              "additionalProperties": true
            },
            "loading": {
              "type": "object",
              "properties": {
                "class": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "array"
                    },
                    {
                      "type": "object"
                    }
                  ]
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "局部样式覆盖配置。"
      }
    ],
    "events": [
      {
        "name": "click",
        "payload": {
          "typeText": "(event: MouseEvent)",
          "typeSchema": {
            "type": "object",
            "x-ts-type": "MouseEvent"
          }
        },
        "emitWhen": [
          {
            "expr": "onClick_called",
            "kind": "runtime-hook"
          }
        ],
        "notEmitWhen": [
          {
            "expr": "native_button_disabled_blocks_click",
            "kind": "platform"
          }
        ],
        "order": [
          "invokeRipple",
          "emit:click"
        ],
        "description": "点击按钮时触发。内部先执行 ripple，再向外派发 click。"
      }
    ],
    "slots": [
      {
        "name": "default",
        "slotPropsSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        },
        "renderWhen": [
          {
            "expr": "always"
          }
        ],
        "fallback": null,
        "description": "按钮主内容（文本或图标）。"
      },
      {
        "name": "loading",
        "slotPropsSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        },
        "renderWhen": [
          {
            "expr": "props.loading === true"
          }
        ],
        "fallback": "LoaderCircle",
        "description": "自定义加载态内容；在 loading=true 时显示。"
      },
      {
        "name": "tooltip",
        "slotPropsSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        },
        "renderWhen": [
          {
            "expr": "not_rendered_in_template"
          }
        ],
        "fallback": null,
        "description": "在 slots 类型中声明，但当前模板未直接渲染。"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": {
            "enum": [
              "xs",
              "sm",
              "base",
              "lg"
            ]
          },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "按钮尺寸（与 tvButton size 变体一致；useTheme 合并后常见为 base）。"
        },
        {
          "name": "skin",
          "typeText": "'razer' | 'shadcn'",
          "typeSchema": {
            "enum": [
              "razer",
              "shadcn"
            ]
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "主题皮肤。"
        },
        {
          "name": "surface",
          "typeText": "'light' | 'dark'",
          "typeSchema": {
            "enum": [
              "light",
              "dark"
            ]
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "全局主题亮/暗表面（data-surface）；勿与 props.color 语义色混淆。"
        },
        {
          "name": "unstyled",
          "typeText": "boolean",
          "typeSchema": {
            "type": "boolean"
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "是否移除默认样式。"
        },
        {
          "name": "bordered",
          "typeText": "boolean",
          "typeSchema": {
            "type": "boolean"
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "是否显示边框。"
        },
        {
          "name": "crafts",
          "typeText": "object",
          "typeSchema": {
            "type": "object"
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "覆盖 tvButton 的 crafts 配置。"
        }
      ]
    },
    "uiConfiguration": {
      "fields": [
        {
          "name": "ui.root.class",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array"
              },
              {
                "type": "object"
              }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "根元素的自定义 class。"
        },
        {
          "name": "ui.loading.class",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array"
              },
              {
                "type": "object"
              }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "加载图标的自定义 class。"
        }
      ]
    }
  },
  "behaviorModel": {
    "stateVars": {
      "variant": "string",
      "color": "string",
      "disabled": "boolean | undefined",
      "loading": "boolean",
      "ripple": "boolean"
    },
    "derived": {
      "rippleEnabled": "ripple === true && disabled !== true",
      "showLoadingSlot": "loading === true",
      "showRippleNode": "ripple === true",
      "rootDataAttrs": "data-variant, data-color, data-surface (theme.surface), data-size (theme.size)"
    },
    "transitions": [
      {
        "on": "click",
        "guard": "disabled !== true",
        "effects": [
          "invokeRipple",
          "emit:click"
        ]
      }
    ]
  },
  "examples": [
    {
      "id": "basic",
      "mcp": {
        "server": "raxium",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Button" },
        "exampleId": "basic"
      },
      "description": "基本用法"
    },
    {
      "id": "variants",
      "mcp": {
        "server": "raxium",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Button" },
        "exampleId": "variants"
      },
      "description": "变体与语义色（variants.vue）"
    },
    {
      "id": "sizes",
      "mcp": {
        "server": "raxium",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Button" },
        "exampleId": "sizes"
      },
      "description": "尺寸配置"
    },
    {
      "id": "crafts",
      "mcp": {
        "server": "raxium",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Button" },
        "exampleId": "crafts"
      },
      "description": "Crafts 主题覆写"
    },
    {
      "id": "theme-example",
      "mcp": {
        "server": "raxium",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Button" },
        "exampleId": "basic"
      },
      "description": "Theme 配置示例（story 内联，无独立 example 文件，可参考 button.stories.ts ThemeExample）"
    },
    {
      "id": "ui-example",
      "mcp": {
        "server": "raxium",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Button" },
        "exampleId": "basic"
      },
      "description": "UI 配置示例（story 内联，无独立 example 文件，可参考 button.stories.ts UIExample）"
    }
  ],
  "generationHints": {
    "preferredUsageOrder": [
      "variant",
      "color",
      "theme.size",
      "loading+disabled",
      "ripple"
    ],
    "safeDefaults": {
      "variant": "solid",
      "color": "primary",
      "ripple": false,
      "loading": false,
      "asChild": false
    },
    "a11yChecklist": [
      "icon-only 按钮建议提供 aria-label。",
      "asChild=true 时确保子元素可聚焦且具备交互语义。",
      "disabled 状态需提供可感知视觉反馈。"
    ],
    "codegenTemplates": {
      "minimal": "<Button>Submit</Button>",
      "semantic": "<Button variant=\"solid\" color=\"primary\">OK</Button>",
      "iconButton": "<Button variant=\"icon\" color=\"primary\"><Icon icon=\"lucide:plus\" /></Button>",
      "asyncAction": "<Button :loading=\"pending\" :disabled=\"pending\">Save</Button>"
    },
    "antiPatterns": [
      "<Button class=\"bg-red-500\">Delete</Button> — 用裸颜色 class 表达语义，应优先 variant + color",
      "<Button @click=\"submit\">Save</Button> — 异步提交未组合 loading + disabled，导致重复触发"
    ]
  },
  "provenance": {
    "sources": [
      {
        "path": "./button.doc.mdx",
        "kind": "doc"
      },
      {
        "path": "./props.ts",
        "kind": "type"
      },
      {
        "path": "./Button.vue",
        "kind": "runtime"
      },
      {
        "path": "../../../../../themes/src/default/crafts/button.ts",
        "kind": "type"
      },
      {
        "path": "./button.stories.ts",
        "kind": "story"
      }
    ],
    "precedence": [
      "runtime",
      "type",
      "doc"
    ],
    "fieldSourceMap": {
      "contracts.props.variant.default": "runtime",
      "contracts.props.color.default": "runtime",
      "contracts.props.tooltip.description": "doc",
      "contracts.events.click.order": "runtime",
      "contracts.themeConfiguration.fields.size.default": "doc",
      "generationHints.safeDefaults": "doc",
      "generationHints.antiPatterns": "doc",
      "behaviorModel.transitions.effects": "runtime"
    }
  }
}
