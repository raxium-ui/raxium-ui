{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.hotkey",
  "component": {
    "name": "Hotkey",
    "framework": "vue",
    "package": "@raxium/vue/core",
    "importPath": "@raxium/vue/core",
    "exportName": "Hotkey",
    "category": "core",
    "description": "用于在页面中采集和展示快捷键组合（如 Ctrl + Shift + K），适合设置中心、编辑器偏好等场景。基于 Ark UI factory 原语（ark.div/ark.input）构建，扩展热键解析、删除清空、IME 输入保护、theme 与 ui 样式配置。",
    "basePrimitive": {
      "library": "@ark-ui/vue/factory",
      "primitive": "ark.div | ark.input",
      "nativeElement": "div | input"
    },
    "passThrough": {
      "htmlAttributes": [
        "aria-*",
        "data-*",
        "disabled",
        "readonly"
      ],
      "notes": "组件基于 factory 原语封装，不对应 Ark UI 独立业务组件；根节点与输入框由 ark.div/ark.input 渲染。"
    },
    "capabilities": [
      "hotkey-capture",
      "v-model",
      "theme",
      "ui-override",
      "ime-protection"
    ]
  },
  "contracts": {
    "props": [
      {
        "name": "hotkey",
        "required": true,
        "requiredSource": "type",
        "typeText": "string",
        "typeSchema": { "type": "string" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "当前热键字符串（配合 v-model:hotkey 使用）。"
      },
      {
        "name": "placeholder",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | ((focused: boolean) => string)",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "function" }
          ]
        },
        "default": "",
        "defaultKind": "explicit-runtime",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "占位文案；可根据焦点状态动态返回文案。"
      },
      {
        "name": "disabled",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "禁用输入与热键采集。"
      },
      {
        "name": "readonly",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "只读展示，不允许变更热键值。"
      },
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | array | object",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "array" },
            { "type": "object" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根节点附加 class。"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ThemeCrafts<'tvHotkey'>",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "主题配置，驱动 tvHotkey crafts。"
      },
      {
        "name": "ui",
        "required": false,
        "requiredSource": "type",
        "typeText": "{ root?: class; input?: class }",
        "typeSchema": {
          "type": "object",
          "properties": {
            "root": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] },
            "input": { "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }] }
          },
          "additionalProperties": false
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "分槽位 UI class 覆盖（root、input）。"
      }
    ],
    "events": [
      {
        "name": "update:hotkey",
        "payload": {
          "typeText": "(value: string)",
          "typeSchema": { "type": "object", "x-ts-type": "string" }
        },
        "emitWhen": [{ "expr": "hotkey_value_changed", "kind": "runtime-machine" }],
        "notEmitWhen": [],
        "order": ["emit:update:hotkey"],
        "description": "热键值更新（用于 v-model:hotkey）。"
      },
      {
        "name": "focus",
        "payload": {
          "typeText": "(event: Event)",
          "typeSchema": { "type": "object", "x-ts-type": "Event" }
        },
        "emitWhen": [{ "expr": "input_focused", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:focus"],
        "description": "输入框获得焦点时触发。"
      },
      {
        "name": "blur",
        "payload": {
          "typeText": "(event: Event)",
          "typeSchema": { "type": "object", "x-ts-type": "Event" }
        },
        "emitWhen": [{ "expr": "input_blurred", "kind": "runtime-hook" }],
        "notEmitWhen": [],
        "order": ["emit:blur"],
        "description": "输入框失焦时触发。"
      },
      {
        "name": "error",
        "payload": {
          "typeText": "(error: Error)",
          "typeSchema": { "type": "object", "x-ts-type": "Error" }
        },
        "emitWhen": [{ "expr": "ime_active_during_input", "kind": "runtime-machine" }],
        "notEmitWhen": [],
        "order": ["emit:error"],
        "description": "异常输入场景回调（如 IME 输入锁定）。"
      },
      {
        "name": "cancel",
        "payload": {
          "typeText": "(keycodes: string[], hotkey: string)",
          "typeSchema": {
            "type": "object",
            "properties": {
              "keycodes": { "type": "array", "items": { "type": "string" } },
              "hotkey": { "type": "string" }
            }
          }
        },
        "emitWhen": [{ "expr": "delete_key_pressed", "kind": "runtime-machine" }],
        "notEmitWhen": [],
        "order": ["emit:update:hotkey", "emit:cancel", "emit:change"],
        "description": "删除动作触发时回调（Backspace/Delete，hotkey 为 'ESC'）。"
      },
      {
        "name": "change",
        "payload": {
          "typeText": "(keycodes: string[], hotkey: string)",
          "typeSchema": {
            "type": "object",
            "properties": {
              "keycodes": { "type": "array", "items": { "type": "string" } },
              "hotkey": { "type": "string" }
            }
          }
        },
        "emitWhen": [{ "expr": "hotkey_successfully_recorded", "kind": "runtime-machine" }],
        "notEmitWhen": [{ "expr": "ime_active", "kind": "runtime-machine" }],
        "order": ["emit:update:hotkey", "emit:change"],
        "description": "成功录入热键后触发，返回规范化按键数组与展示文本。"
      }
    ],
    "slots": [],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": { "enum": ["xs", "sm", "base", "lg"] },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "尺寸主题变体。"
        },
        {
          "name": "skin",
          "typeText": "'razer' | 'shadcn'",
          "typeSchema": { "enum": ["razer", "shadcn"] },
          "default": null,
          "defaultKind": "unknown",
          "description": "皮肤风格选择。"
        },
        {
          "name": "surface",
          "typeText": "'light' | 'dark'",
          "typeSchema": { "enum": ["light", "dark"] },
          "default": null,
          "defaultKind": "unknown",
          "description": "表面模式。"
        },
        {
          "name": "bordered",
          "typeText": "boolean",
          "typeSchema": { "type": "boolean" },
          "default": null,
          "defaultKind": "unknown",
          "description": "是否启用边框风格。"
        },
        {
          "name": "unstyled",
          "typeText": "boolean",
          "typeSchema": { "type": "boolean" },
          "default": null,
          "defaultKind": "unknown",
          "description": "是否移除内置样式。"
        },
        {
          "name": "crafts",
          "typeText": "object | (() => tv)",
          "typeSchema": { "type": "object" },
          "default": null,
          "defaultKind": "unknown",
          "description": "覆写 tvHotkey。"
        }
      ]
    },
    "uiConfiguration": {
      "fields": [
        {
          "name": "ui.root",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "根容器 class 覆盖。"
        },
        {
          "name": "ui.input",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "输入框 class 覆盖。"
        }
      ]
    }
  },
  "behaviorModel": {
    "stateVars": {
      "hotkey": "string",
      "disabled": "boolean | undefined",
      "readonly": "boolean | undefined",
      "isFocus": "boolean"
    },
    "derived": {
      "inputState": "disabled ? 'disabled' : readonly ? 'readonly' : isFocus ? 'focused' : 'blur'",
      "canRecord": "!disabled && !readonly && isFocus"
    },
    "transitions": [
      {
        "on": "keydown",
        "guard": "canRecord && !repeat && keyCode < 229",
        "effects": ["recordKeycodes", "updateDisplay"]
      },
      {
        "on": "keyup",
        "guard": "canRecord",
        "effects": ["finalizeOrReset", "emit:update:hotkey", "emit:cancel", "emit:change"]
      },
      {
        "on": "blur",
        "guard": "always",
        "effects": ["setInnerHotkey", "resetData", "emit:blur"]
      }
    ]
  },
