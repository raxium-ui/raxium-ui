  "generationHints": {
    "preferredUsageOrder": [
      "hotkey (v-model:hotkey)",
      "placeholder",
      "theme.size",
      "ui.root",
      "ui.input"
    ],
    "safeDefaults": {
      "placeholder": "",
      "disabled": false,
      "readonly": false
    },
    "a11yChecklist": [
      "输入框具备 aria-label 或等效可访问名称。",
      "禁用态使用 disabled 语义，不仅是视觉灰化。",
      "IME 场景建议监听 error 并给用户可见提示。"
    ],
    "codegenTemplates": {
      "minimal": "<Hotkey v-model:hotkey=\"hotkey\" />",
      "withPlaceholder": "<Hotkey v-model:hotkey=\"hotkey\" placeholder=\"Press hotkey\" />"
    },
    "antiPatterns": [
      "<Hotkey class=\"opacity-50\" /> 未设置 :disabled=\"true\"，仅用 class 模拟 disabled。",
      "在 @focus 或 @blur 中持久化热键，而非 @change，导致与 v-model 状态不同步。"
    ]
  },
