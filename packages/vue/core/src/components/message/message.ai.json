            "name": "skin",
            "typeText": "'razer' | 'shadcn'",
            "typeSchema": { "enum": ["razer", "shadcn"] },
            "default": null,
            "defaultKind": "unknown",
            "description": "主题皮肤。"
          }
        ]
      },
      "uiConfiguration": {
        "fields": [
