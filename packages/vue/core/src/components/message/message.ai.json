                "type": "string",
                "enum": ["info", "success", "warning", "error", "loading"]
              },
              "description": {},
              "render": { "type": "function" },
              "showClose": { "type": "boolean" },
              "theme": { "type": "object" }
            },
            "required": []
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "nullable": false,
          "passthrough": false,
          "deprecated": false,
          "dependsOn": [],
          "conflictsWith": [],
          "description": "单条消息配置（必填），含 type、description、render、showClose、theme。"
        },
        {
          "name": "class",
          "required": false,
          "requiredSource": "type",
          "typeText": "string | string[] | Record<string, boolean>",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } },
              { "type": "object" }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "nullable": true,
          "passthrough": false,
          "deprecated": false,
          "dependsOn": [],
