{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.message",
  "component": {
    "name": "Message",
    "framework": "vue",
    "package": "@raxium/vue/core",
    "importPath": "@raxium/vue/core",
    "exportName": "Messager",
    "category": "core",
    "description": "基于 Ark UI Toast 能力封装的全局消息提示方案，适合反馈异步结果、状态变更与轻量通知。组件由 Messager（消息容器/根）与 Message（单条消息渲染）组合而成，支持 useMessage() 编程式 API、主题配置（theme）与样式覆盖（ui）。",
    "basePrimitive": {
      "library": "@ark-ui/vue/toast",
      "primitive": "Toaster",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": [],
      "notes": "Messager 使用 createToaster 与 Toaster，固定 placement: 'top'；Message 基于 Toast.Root 渲染单条消息，透传 ToastRootBaseProps。Messager 本身不提供 ui 字段，样式覆盖入口位于 Message.ui。"
    },
    "capabilities": [
      "imperative-api",
      "theme",
      "ui-override",
      "custom-render",
      "promise-lifecycle"
    ],
    "subComponents": ["Message"]
  },
