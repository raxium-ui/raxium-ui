          "name": "crafts",
          "typeText": "object",
          "typeSchema": { "type": "object" },
          "default": null,
          "defaultKind": "unknown",
          "description": "覆盖 tvMessage crafts。"
        }
      ]
    },
    "uiConfiguration": { "fields": [] }
  },
  "subComponents": {
    "Message": {
