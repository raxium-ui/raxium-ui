          "name": "default",
          "slotPropsSchema": {
            "type": "object",
            "properties": {
              "options": {},
              "context": {}
            }
          },
          "renderWhen": [{ "expr": "!options?.render" }],
          "fallback": null,
          "description": "自定义整条消息结构；作用域参数含 options 与 context。"
        },
        {
          "name": "icon",
          "slotPropsSchema": {
            "type": "object",
            "properties": {
              "options": {},
              "context": {}
            }
          },
          "renderWhen": [{ "expr": "!options?.render" }],
          "fallback": "按 type 渲染默认图标",
          "description": "覆盖默认类型图标区域。"
        },
        {
          "name": "inner",
          "slotPropsSchema": {
            "type": "object",
            "properties": {
              "options": {},
              "context": {}
            }
          },
          "renderWhen": [{ "expr": "!options?.render" }],
          "fallback": "Toast.Description",
          "description": "覆盖描述区域内容。"
        },
        {
          "name": "close",
          "slotPropsSchema": {
            "type": "object",
            "properties": {
              "options": {},
              "context": {}
            }
          },
          "renderWhen": [{ "expr": "options?.showClose === true && context?.type !== 'loading'" }],
          "fallback": "Toast.CloseTrigger",
          "description": "覆盖关闭按钮区域；仅在 options.showClose 为真时渲染，loading 类型默认不渲染关闭按钮。"
        }
      ],
