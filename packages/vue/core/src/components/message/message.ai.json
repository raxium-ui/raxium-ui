              "description": "MessageOptions，含 showClose 等合并后的消息对象"
            }
          }
        },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "返回 { message }，用于将当前消息对象绑定到 Message 渲染。"
