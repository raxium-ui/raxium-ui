  "generationHints": {
    "preferredUsageOrder": [
      "Messager 挂载",
      "useMessage().message.create/success/error/info/warning/loading",
      "message.promise() 统一管理异步生命周期",
      "options.type",
      "options.description",
      "options.showClose"
    ],
    "safeDefaults": {
      "Messager.showClose": true,
      "Messager.max": 24,
      "Messager.gap": 16,
      "Messager.offsets": "1rem",
      "Messager.hotkey": ["altKey", "KeyT"],
      "Messager.removeDelay": 200,
      "Messager.pauseOnPageIdle": false,
      "Message.options": "必填"
    },
    "a11yChecklist": [
      "应用根部至少挂载一个 Messager",
      "消息类型需提供可感知的视觉反馈",
      "loading 类型默认不显示关闭按钮",
      "duration: Infinity 时应提供可见关闭入口"
    ],
    "codegenTemplates": {
      "minimal": "<Messager><template #default=\"{ message }\"><Message :options=\"message\" /></template></Messager>",
      "withUseMessage": "const { message } = useMessage(); message.success({ description: '操作成功' });",
      "useMessagePromise": "const { message } = useMessage(); message.promise(fetchData(), { loading: '加载中...', success: '完成', error: '失败' });",
      "fullSetup": "<Messager :show-close=\"true\" :max=\"24\"><template #default=\"{ message }\"><Message :options=\"message\" /></template></Messager>"
    },
    "antiPatterns": [
      "在未挂载 <Messager /> 的组件树中调用 useMessage().message.success({ description: 'ok' })",
      "message.create({ description: '失败' }) 未设置 type: 'error'",
      "手动 try/catch 分别调用 loading/success/error 而非 message.promise(p, { loading, success, error })"
    ]
  },
