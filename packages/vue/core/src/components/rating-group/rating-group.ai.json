    "basePrimitive": {
      "library": "@ark-ui/vue/rating-group",
      "primitive": "RatingGroup.RootProvider",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": ["aria-*", "data-*"],
      "notes": "组件基于 Ark UI Rating Group 原语封装，透传 Root 常用能力。"
    },
    "capabilities": [
      "v-model",
      "theme",
      "ui-override",
      "allow-half",
      "programmatic-api"
    ],
    "subComponents": ["RatingGroupItem"]
  },
