  "generationHints": {
    "preferredUsageOrder": [
      "modelValue / defaultValue",
      "count",
      "allowHalf",
      "theme.size",
      "disabled / readOnly",
      "RatingGroupItem.index"
    ],
    "safeDefaults": {
      "count": 5,
      "allowHalf": false,
      "disabled": false,
      "readOnly": false
    },
    "a11yChecklist": [
      "评分组件需提供 aria-label 或 aria-labelledby 说明用途",
      "readOnly 与 disabled 语义不同，需区分使用",
      "半星评分需考虑屏幕阅读器对部分值的表达"
    ],
    "codegenTemplates": {
      "minimal": "<RatingGroup v-model=\"rating\">\n  <template #default=\"{ items }\">\n    <RatingGroupItem v-for=\"item in items\" :key=\"item\" :index=\"item\" />\n  </template>\n</RatingGroup>",
      "controlled": "<RatingGroup v-model=\"rating\" :count=\"5\" :allow-half=\"true\">\n  <template #default=\"{ items }\">\n    <RatingGroupItem v-for=\"item in items\" :key=\"item\" :index=\"item\" />\n  </template>\n</RatingGroup>",
      "withTheme": "<RatingGroup v-model=\"rating\" :theme=\"{ size: 'sm' }\">\n  <template #default=\"{ items }\">\n    <RatingGroupItem v-for=\"item in items\" :key=\"item\" :index=\"item\" />\n  </template>\n</RatingGroup>",
      "customItem": "<RatingGroup v-model=\"rating\">\n  <template #default=\"{ items }\">\n    <RatingGroupItem v-for=\"item in items\" :key=\"item\" :index=\"item\">\n      <template #default=\"{ classes, context }\">\n        <span :class=\"classes.indicator\" :data-highlighted=\"context.highlighted\">\n          <Star :class=\"classes.icon\" />\n        </span>\n      </template>\n    </RatingGroupItem>\n  </template>\n</RatingGroup>"
    },
    "antiPatterns": [
      "<RatingGroup v-model=\"rating\" :default-value=\"3\" /> — 同时使用 modelValue 与 defaultValue 导致冲突",
      "<RatingGroup v-model=\"rating\"><RatingGroupItem :index=\"0\" /></RatingGroup> — 未使用 default 插槽的 items 遍历，缺少完整评分项",
      "<RatingGroup v-model=\"rating\" read-only><span class=\"opacity-50\">禁用</span></RatingGroup> — 仅靠视觉样式模拟禁用（应使用 disabled）"
    ]
  },
