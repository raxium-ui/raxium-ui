{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.spin",
  "component": {
    "name": "Spin",
    "framework": "vue",
    "package": "@raxium/vue/core",
    "importPath": "@raxium/vue/core",
    "exportName": "Spin",
    "category": "core",
    "description": "用于加载中状态反馈的遮罩组件，支持在局部容器内覆盖（inline）或全屏覆盖（fullscreen）。基于 Ark UI Factory 原语与 Raxium UI 主题体系构建，支持 theme 与 ui 分槽位样式配置，并可通过 SpinProvider 统一注入默认或自定义加载图标。",
    "basePrimitive": {
      "library": "@ark-ui/vue/factory",
      "primitive": "ark.span",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": ["aria-*", "data-*"],
      "notes": "组件基于 Ark UI Factory 原语封装，非 Ark UI 独立 Spin 组件。"
    },
    "capabilities": [
      "theme",
      "ui-override",
      "fullscreen-inline",
      "delay-hide",
      "provider-icon"
    ],
    "parentComponents": ["SpinProvider"]
  },
  "contracts": {
    "props": [
      {
        "name": "show",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": false,
        "defaultKind": "explicit-doc",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "是否显示加载层（未传时不显示）"
      },
      {
        "name": "mode",
        "required": false,
        "requiredSource": "doc",
        "typeText": "'fullscreen' | 'inline'",
        "typeSchema": {
          "enum": ["fullscreen", "inline"]
        },
        "default": "inline",
        "defaultKind": "explicit-doc",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "覆盖模式：局部容器覆盖或全屏覆盖"
      },
      {
        "name": "delay",
        "required": false,
        "requiredSource": "type",
        "typeText": "number",
        "typeSchema": { "type": "number" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "隐藏延迟（毫秒）；仅在 show 从 true 变为 false 时生效"
      },
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | array | object",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "array" },
            { "type": "object" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根节点附加 class"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ThemeCrafts<'tvSpin'>",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "主题参数与 tvSpin crafts 覆盖"
      },
      {
        "name": "ui",
        "required": false,
        "requiredSource": "type",
        "typeText": "{ root?: string | array | object; mask?: string | array | object; indicator?: string | array | object; text?: string | array | object }",
        "typeSchema": {
          "type": "object",
          "properties": {
            "root": {
              "anyOf": [
                { "type": "string" },
                { "type": "array" },
                { "type": "object" }
              ]
            },
            "mask": {
              "anyOf": [
                { "type": "string" },
                { "type": "array" },
                { "type": "object" }
              ]
            },
            "indicator": {
              "anyOf": [
                { "type": "string" },
                { "type": "array" },
                { "type": "object" }
              ]
            },
            "text": {
              "anyOf": [
                { "type": "string" },
                { "type": "array" },
                { "type": "object" }
              ]
            }
          },
          "additionalProperties": true
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "局部样式覆盖配置（ui.root、ui.mask、ui.indicator、ui.text 为 class 覆盖）"
      }
    ],
    "events": [],
    "slots": [
      {
        "name": "default",
        "slotPropsSchema": {
          "type": "object",
          "properties": {
            "mode": { "type": "string" },
            "theme": { "type": "object" }
          },
          "additionalProperties": true
        },
        "renderWhen": [{ "expr": "always" }],
        "fallback": "SpinProvider.renderIcon",
        "description": "自定义加载图标区域，插槽参数为 { mode, theme }"
      },
      {
        "name": "text",
        "slotPropsSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "自定义加载文本区域内容"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": {
            "enum": ["xs", "sm", "base", "lg"]
          },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "控制加载图标与相关间距尺寸"
        },
        {
          "name": "skin",
          "typeText": "'razer' | 'shadcn'",
          "typeSchema": {
            "enum": ["razer", "shadcn"]
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "主题皮肤"
        },
        {
          "name": "surface",
          "typeText": "'light' | 'dark' | string",
          "typeSchema": {
            "anyOf": [
              { "enum": ["light", "dark"] },
              { "type": "string" }
            ]
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "表面语义（亮/暗或自定义语义）"
        },
        {
          "name": "unstyled",
          "typeText": "boolean",
          "typeSchema": { "type": "boolean" },
          "default": null,
          "defaultKind": "unknown",
          "description": "移除内置样式"
        },
        {
          "name": "bordered",
          "typeText": "boolean",
          "typeSchema": { "type": "boolean" },
          "default": null,
          "defaultKind": "unknown",
          "description": "启用边框语义（是否生效取决于 tvSpin 具体实现）"
        },
        {
          "name": "crafts",
          "typeText": "object",
          "typeSchema": { "type": "object" },
          "default": null,
          "defaultKind": "unknown",
          "description": "覆盖 tvSpin 的 crafts 配置"
        }
      ]
    },
    "uiConfiguration": {
      "fields": [
        {
          "name": "ui.root",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "array" },
              { "type": "object" }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "根容器样式覆盖"
        },
        {
          "name": "ui.mask",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "array" },
              { "type": "object" }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "遮罩层样式覆盖"
        },
        {
          "name": "ui.indicator",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "array" },
              { "type": "object" }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "指示器容器样式覆盖"
        },
        {
          "name": "ui.text",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "array" },
              { "type": "object" }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "文本区域样式覆盖"
        }
      ]
    }
  },
  "parentComponents": {
    "SpinProvider": {
      "props": [],
      "slots": [
        {
          "name": "default",
          "slotPropsSchema": {
            "type": "object",
            "properties": {},
            "additionalProperties": false
          },
          "renderWhen": [{ "expr": "always" }],
          "fallback": null,
          "description": "包裹业务内容并向后代 Spin 提供图标渲染上下文"
        },
        {
          "name": "icon",
          "slotPropsSchema": {
            "type": "object",
            "properties": {
              "mode": { "type": "string" },
              "theme": { "type": "object" },
              "class": {
                "anyOf": [
                  { "type": "string" },
                  { "type": "array" },
                  { "type": "object" }
                ]
              }
            },
            "additionalProperties": true
          },
          "renderWhen": [{ "expr": "always" }],
          "fallback": "LoaderCircle",
          "description": "全局自定义图标渲染，插槽参数为 { mode, theme, class }"
        }
      ],
      "events": [],
      "themeConfiguration": {
        "fields": []
      },
      "uiConfiguration": {
        "fields": []
      }
    }
  },
  "behaviorModel": {
    "stateVars": {
      "show": "boolean",
      "mode": "'fullscreen' | 'inline'",
      "delay": "number | undefined"
    },
    "derived": {
      "isVisible": "show === true 或 (show 刚变为 false 且 delay 未到)"
    },
    "transitions": [
      {
        "on": "show_true",
        "guard": "always",
        "effects": ["setIsVisible(true)", "updateParentPosition()"]
      },
      {
        "on": "show_false",
        "guard": "delay ? scheduleHide : immediate",
        "effects": ["scheduleHide(delay)", "setIsVisible(false)", "restoreParentPosition()"]
      }
    ]
  },
