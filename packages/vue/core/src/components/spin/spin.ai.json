  "generationHints": {
    "preferredUsageOrder": [
      "show",
      "mode",
      "theme.size",
      "delay",
      "text slot"
    ],
    "safeDefaults": {
      "show": false,
      "mode": "inline"
    },
    "a11yChecklist": [
      "加载层需提供 aria-busy 或 aria-live 语义",
      "inline 模式建议父容器具备明确尺寸",
      "delay 隐藏时建议保持足够时长避免闪烁"
    ],
    "codegenTemplates": {
      "minimal": "<Spin :show=\"loading\" />",
      "withText": "<Spin :show=\"loading\"><template #text>加载中...</template></Spin>",
      "withProvider": "<SpinProvider><template #icon=\"{ class: klass }\"><CustomIcon :class=\"klass\" /></template><div>业务内容</div><Spin :show=\"loading\" /></SpinProvider>"
    },
    "antiPatterns": [
      "<Spin :show=\"loading\" mode=\"fullscreen\" /> — 全屏加载用于非阻塞式流程（如局部 tab 切换）应使用 mode=\"inline\"",
      "<Spin :show=\"loading\" /> — 请求瞬时结束导致闪烁时应使用 delay 参数",
      "<div><Spin :show=\"true\" mode=\"inline\" /></div> — inline 模式父容器无尺寸导致遮罩抖动，父 div 需设 height/min-height"
    ]
  },
