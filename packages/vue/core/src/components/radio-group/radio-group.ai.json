  "generationHints": {
    "preferredUsageOrder": [
      "modelValue / defaultValue",
      "orientation",
      "theme.size",
      "RadioGroupItem.value",
      "RadioGroupItem.variant",
      "RadioGroupItem.ui"
    ],
    "safeDefaults": {
      "orientation": "horizontal",
      "RadioGroupItem.variant": "default"
    },
    "a11yChecklist": [
      "同一组选项保持 value 类型一致",
      "组级 label 插槽或 aria-label 提供可访问性说明",
      "disabled 状态需提供可感知视觉反馈"
    ],
    "codegenTemplates": {
      "minimal": "<RadioGroup v-model=\"value\">\n  <RadioGroupItem value=\"a\" label=\"A\" />\n  <RadioGroupItem value=\"b\" label=\"B\" />\n</RadioGroup>",
      "controlled": "<RadioGroup v-model=\"selected\" orientation=\"vertical\">\n  <RadioGroupItem value=\"1\" label=\"选项 1\" />\n  <RadioGroupItem value=\"2\" label=\"选项 2\" />\n</RadioGroup>",
      "withUi": "<RadioGroup v-model=\"value\">\n  <RadioGroupItem value=\"a\" label=\"A\" :ui=\"{ indicator: 'ring-2' }\" />\n  <RadioGroupItem value=\"b\" label=\"B\" />\n</RadioGroup>",
      "customSlots": "<RadioGroup v-model=\"value\">\n  <RadioGroupItem value=\"a\">\n    <template #default=\"{ checked }\">{{ checked ? '已选 A' : 'A' }}</template>\n  </RadioGroupItem>\n  <RadioGroupItem value=\"b\" label=\"B\" />\n</RadioGroup>"
    },
    "antiPatterns": [
      "<RadioGroup v-model=\"v\" :default-value=\"'x'\">...</RadioGroup> modelValue 与 defaultValue 同时使用（受控与非受控互斥）",
      "<RadioGroup><RadioGroupItem value=\"1\" /> <RadioGroupItem value=\"two\" /> </RadioGroup> 同一组内 value 类型混用（应统一为 string 或 number）",
      "<RadioGroupItem value=\"a\" /> 未使用 label 或默认插槽导致选项无文本（应提供 label 或 default slot）",
      "<RadioGroupItem value=\"a\" class=\"opacity-50\" /> 仅靠视觉样式模拟禁用（应使用 disabled）"
    ]
  },
