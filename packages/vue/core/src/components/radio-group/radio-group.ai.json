{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.radio-group",
  "component": {
    "name": "RadioGroup",
    "framework": "vue",
    "package": "@raxium/vue/core",
    "importPath": "@raxium/vue/core",
    "exportName": "RadioGroup",
    "category": "core",
    "description": "用于管理单选集合场景，适合筛选条件、配置项切换、设置面板等只允许选择一个值的交互。基于 Ark UI Radio Group 原语构建，支持受控/非受控值管理，并扩展 theme、variant 以及 ui 样式入口。由 RadioGroup（根）与 RadioGroupItem（子组件）组成；RadioGroupItem 承载单选项，扩展 label、variant 与 ui 样式入口。",
    "basePrimitive": {
      "library": "@ark-ui/vue/radio-group",
      "primitive": "RadioGroup.RootProvider",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": ["aria-*", "data-*"],
      "notes": "组件基于 Ark UI Radio Group 封装，通过 useRadioGroup 承接组值状态。"
    },
    "capabilities": [
      "v-model",
      "theme",
      "ui-override",
      "orientation",
      "composite-item"
    ],
    "subComponents": ["RadioGroupItem"]
  },
