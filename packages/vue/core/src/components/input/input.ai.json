        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Input" },
        "exampleId": "prefix-suffix-and-ui"
      },
      "description": "前后缀插槽与 UI 覆盖"
    }
  ],
  "generationHints": {
    "preferredUsageOrder": [
      "modelValue / defaultValue",
      "placeholder",
      "clearable",
      "theme.size",
      "disabled / readonly"
    ],
    "safeDefaults": {
      "clearable": false,
      "disabled": false,
      "readonly": false,
      "defaultValue": ""
    },
    "a11yChecklist": [
      "placeholder 不能替代 label，需配合 label 或 aria-label 使用",
      "disabled/readonly 状态需提供可感知视觉反馈",
      "maxlength 建议配合 aria-describedby 提示剩余字数"
    ],
    "codegenTemplates": {
      "minimal": "<Input v-model=\"value\" placeholder=\"请输入\" />",
      "controlled": "<Input v-model=\"value\" placeholder=\"请输入\" :clearable=\"true\" />"
    },
    "antiPatterns": [
      "<Input placeholder=\"请输入\" /> 未配合 label 或 aria-label",
      "同时设置 :readonly=\"true\" :disabled=\"true\" 导致语义不清",
      "<Input v-model=\"q\" :clearable=\"true\" /> 未监听 @update:modelValue 导致业务状态不同步"
    ]
  },
