{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.input",
  "component": {
    "name": "Input",
    "framework": "vue",
    "package": "@raxium/vue/core",
    "importPath": "@raxium/vue/core",
    "exportName": "Input",
    "category": "core",
    "description": "用于采集单行文本或数字输入，适合表单、筛选栏、搜索框等场景。基于 Ark UI Vue factory 原语（ark.div）构建输入容器，在原生输入行为之上补充 clearable 清空能力、prefix/suffix 插槽、theme 主题参数与 ui 局部样式覆盖入口。",
    "basePrimitive": {
      "library": "@ark-ui/vue/factory",
      "primitive": "ark.div",
      "nativeElement": "input"
    },
    "passThrough": {
      "htmlAttributes": [
        "id",
        "placeholder",
        "maxlength",
        "disabled",
        "readonly",
        "aria-*",
        "data-*"
      ],
      "notes": "组件基于 factory 原语封装，内部使用原生 input 元素，非 Ark UI 独立业务组件。"
    },
    "capabilities": [
      "v-model",
      "clearable",
      "theme",
      "ui-override",
      "prefix-suffix-slots"
    ]
  },
  "contracts": {
