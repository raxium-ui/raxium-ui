        "required": false,
        "requiredSource": "type",
        "typeText": "string | number",
        "typeSchema": {
          "anyOf": [{ "type": "string" }, { "type": "number" }]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": ["defaultValue"],
        "description": "受控值（配合 v-model 使用）"
      },
      {
        "name": "defaultValue",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | number",
        "typeSchema": {
          "anyOf": [{ "type": "string" }, { "type": "number" }]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
