      { "path": "./Input.vue", "kind": "runtime" },
      { "path": "./input.stories.ts", "kind": "story" }
    ],
    "precedence": ["runtime", "type", "doc"],
    "fieldSourceMap": {
      "contracts.props.clearable.default": "runtime",
      "contracts.props.modelValue.conflictsWith": "doc",
