        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "是否禁用输入"
      },
      {
        "name": "readonly",
        "required": false,
        "requiredSource": "type",
        "typeText": "boolean",
        "typeSchema": { "type": "boolean" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": true,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "是否只读"
      },
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "string | array | object",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "array" },
            { "type": "object" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "根容器附加 class"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "ThemeCrafts<'tvInput'>",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "主题参数与 crafts 覆写入口"
      },
      {
        "name": "ui",
        "required": false,
        "requiredSource": "type",
        "typeText": "{ root?: HTMLAttributes['class'], input?: HTMLAttributes['class'], clearable?: HTMLAttributes['class'] }",
        "typeSchema": {
          "type": "object",
          "properties": {
            "root": {
              "anyOf": [
                { "type": "string" },
                { "type": "array" },
                { "type": "object" }
              ]
            },
            "input": {
              "anyOf": [
                { "type": "string" },
                { "type": "array" },
                { "type": "object" }
              ]
            },
            "clearable": {
              "anyOf": [
                { "type": "string" },
                { "type": "array" },
                { "type": "object" }
              ]
            }
          },
          "additionalProperties": true
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "局部样式覆盖配置"
      }
    ],
    "events": [
      {
        "name": "update:modelValue",
        "payload": {
          "typeText": "(value: string | number)",
          "typeSchema": {
            "anyOf": [{ "type": "string" }, { "type": "number" }]
          }
        },
        "emitWhen": [
          { "expr": "modelValue_changed", "kind": "runtime-hook" }
        ],
        "notEmitWhen": [],
        "order": ["emit:update:modelValue"],
        "description": "输入值变化时触发，用于 v-model 同步"
      },
      {
        "name": "focus",
        "payload": {
          "typeText": "(event: Event)",
          "typeSchema": { "type": "object", "x-ts-type": "Event" }
        },
        "emitWhen": [
          { "expr": "input_focus", "kind": "runtime-hook" }
        ],
        "notEmitWhen": [],
        "order": ["emit:focus"],
        "description": "输入框获得焦点时触发"
      },
      {
        "name": "blur",
        "payload": {
          "typeText": "(event: Event)",
          "typeSchema": { "type": "object", "x-ts-type": "Event" }
        },
        "emitWhen": [
          { "expr": "input_blur", "kind": "runtime-hook" }
        ],
        "notEmitWhen": [],
        "order": ["emit:blur"],
        "description": "输入框失焦时触发"
      },
      {
        "name": "input",
        "payload": {
          "typeText": "(event: Event, value: string | number | undefined)",
          "typeSchema": {
            "type": "array",
            "items": [
              { "type": "object", "x-ts-type": "Event" },
              {
                "anyOf": [
                  { "type": "string" },
                  { "type": "number" },
                  { "type": "null" }
                ]
              }
            ]
          }
        },
        "emitWhen": [
          { "expr": "native_input_event", "kind": "runtime-hook" }
        ],
        "notEmitWhen": [],
        "order": ["emit:input"],
        "description": "原生输入事件回调，并返回当前值"
      },
      {
        "name": "change",
        "payload": {
          "typeText": "(event: Event, value: string | number | undefined)",
          "typeSchema": {
            "type": "array",
            "items": [
              { "type": "object", "x-ts-type": "Event" },
              {
                "anyOf": [
                  { "type": "string" },
                  { "type": "number" },
                  { "type": "null" }
                ]
              }
            ]
          }
        },
        "emitWhen": [
          { "expr": "native_change_event", "kind": "runtime-hook" }
        ],
        "notEmitWhen": [],
        "order": ["emit:change"],
        "description": "原生 change 事件回调，并返回当前值"
      }
    ],
    "slots": [
      {
        "name": "prefix",
        "slotPropsSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "输入框前置内容，常用于图标或前缀文本"
      },
      {
        "name": "suffix",
        "slotPropsSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        },
        "renderWhen": [{ "expr": "always" }],
        "fallback": null,
        "description": "输入框后置内容，常用于快捷提示或状态标识"
      }
    ],
    "themeConfiguration": {
      "fields": [
        {
          "name": "size",
          "typeText": "'xs' | 'sm' | 'base' | 'lg'",
          "typeSchema": {
            "enum": ["xs", "sm", "base", "lg"]
          },
          "default": "base",
          "defaultKind": "explicit-doc",
          "description": "尺寸主题变体（crafts tvInput defaultVariants）"
        },
        {
          "name": "skin",
          "typeText": "'razer' | 'shadcn'",
          "typeSchema": {
            "enum": ["razer", "shadcn"]
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "皮肤风格"
        },
        {
          "name": "surface",
          "typeText": "'light' | 'dark'",
          "typeSchema": {
            "enum": ["light", "dark"]
          },
          "default": null,
          "defaultKind": "unknown",
          "description": "表面模式"
        },
        {
          "name": "bordered",
          "typeText": "boolean",
          "typeSchema": { "type": "boolean" },
          "default": null,
          "defaultKind": "unknown",
          "description": "是否启用边框风格"
        },
        {
          "name": "unstyled",
          "typeText": "boolean",
          "typeSchema": { "type": "boolean" },
          "default": null,
          "defaultKind": "unknown",
          "description": "是否移除内置样式"
        },
        {
          "name": "crafts",
          "typeText": "object",
          "typeSchema": { "type": "object" },
          "default": null,
          "defaultKind": "unknown",
          "description": "覆写 tvInput 或注入自定义 crafts"
        }
      ]
    },
    "uiConfiguration": {
      "fields": [
        {
          "name": "ui.root.class",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "array" },
              { "type": "object" }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "外层容器 class 覆盖"
        },
        {
          "name": "ui.input.class",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "array" },
              { "type": "object" }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "输入框 class 覆盖"
        },
        {
          "name": "ui.clearable.class",
          "typeText": "string | array | object",
          "typeSchema": {
            "anyOf": [
              { "type": "string" },
              { "type": "array" },
              { "type": "object" }
            ]
          },
          "default": null,
          "defaultKind": "implicit-undefined",
          "description": "清空按钮 class 覆盖"
        }
      ]
    }
  },
  "behaviorModel": {
    "stateVars": {
      "modelValue": "string | number | undefined",
      "isFocus": "boolean",
      "disabled": "boolean | undefined",
      "readonly": "boolean | undefined",
      "clearable": "boolean"
    },
    "derived": {
      "inputState": "disabled ? 'disabled' : readonly ? 'readonly' : isFocus ? 'focused' : 'blur'",
      "showClearable": "inputState === 'focused' && clearable && modelValue"
    },
    "transitions": [
      {
        "on": "focus",
        "guard": "disabled !== true",
        "effects": ["setIsFocus(true)", "emit:focus"]
      },
      {
        "on": "blur",
        "guard": "!rejectBlur",
        "effects": ["setIsFocus(false)", "emit:blur"]
      },
      {
        "on": "input",
        "guard": "always",
        "effects": ["updateModelValue(value)", "emit:update:modelValue", "emit:input"]
      },
      {
        "on": "clearable_click",
        "guard": "showClearable",
        "effects": ["setModelValue('')", "focusInput"]
      }
    ]
  },
