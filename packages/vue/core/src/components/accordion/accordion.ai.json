{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.accordion",
  "component": {
    "name": "Accordion",
    "framework": "vue",
    "package": "@raxium/vue/core",
    "importPath": "@raxium/vue/core",
    "exportName": "Accordion",
    "category": "core",
    "description": "用于将内容分成多个可独立展开/收起的面板，适合 FAQ、设置分组与长内容分节。基于 Ark UI Accordion 原语封装，包含 Accordion、AccordionItem（别名 AccordionPanel）、AccordionTrigger、AccordionContent；根组件扩展 theme/class，触发器扩展 indicator 与 ui。",
    "basePrimitive": {
      "library": "@ark-ui/vue/accordion",
      "primitive": "Accordion.RootProvider",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": [
        "id",
        "disabled",
        "aria-*",
        "data-*"
      ],
      "notes": "根组件透传 Ark Accordion Root 状态与方向等能力；Item/Trigger/Content 透传对应 Ark 子原语属性。透传边界以 props.ts 中 interface 继承为准。"
    },
    "capabilities": [
      "expand-collapse",
      "multiple",
      "collapsible",
      "controlled",
      "uncontrolled",
      "theme",
      "ui-override",
      "slot-composition",
      "lazy-mount"
    ],
    "subComponents": ["AccordionItem", "AccordionTrigger", "AccordionContent", "AccordionPanel"]
  },
