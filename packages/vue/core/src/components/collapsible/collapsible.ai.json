  "behaviorModel": {
    "stateVars": {
      "open": "boolean | undefined",
      "defaultOpen": "boolean | undefined",
      "disabled": "boolean | undefined",
      "collapsedHeight": "number | string | undefined",
      "measuredHeight": "number",
      "indicator": "boolean"
    },
    "derived": {
      "isControlled": "open !== undefined",
      "canToggle": "disabled !== true",
      "showIndicatorFallback": "indicator === true && !hasSlot('indicator')",
      "collapsedHeightPx": "typeof collapsedHeight === 'string' ? rem2px(collapsedHeight) : collapsedHeight",
      "showReadMoreTrigger": "measuredHeight > collapsedHeightPx"
    },
    "transitions": [
      {
        "on": "trigger-click",
        "guard": "canToggle",
        "effects": [
          "emit:update:open",
          "emit:openChange"
        ]
      },
      {
        "on": "content-resize",
        "guard": "component === ReadMore",
        "effects": [
          "recompute(measuredHeight)",
          "set(showReadMoreTrigger)"
        ]
      }
    ]
  },
