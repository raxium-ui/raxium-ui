      "library": "@ark-ui/vue/collapsible",
      "primitive": "Collapsible.RootProvider",
      "nativeElement": "div"
    },
    "passThrough": {
      "htmlAttributes": [
        "id",
        "disabled",
        "aria-*",
        "data-*"
      ],
      "notes": "Collapsible 根组件透传 Ark UI Root 常用状态属性；Trigger/Content 透传 Ark 子原语属性。"
    },
    "capabilities": [
      "expand-collapse",
      "controlled",
      "uncontrolled",
      "read-more",
      "theme",
      "ui-override",
      "slot-composition"
    ],
    "subComponents": ["CollapsibleTrigger", "CollapsibleContent", "ReadMore"]
  },
