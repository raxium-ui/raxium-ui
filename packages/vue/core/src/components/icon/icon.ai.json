{
  "schemaVersion": "2.0.0",
  "docId": "rark.vue.icon",
  "component": {
    "name": "Icon",
    "framework": "vue",
    "package": "@raxium/vue/core",
    "importPath": "@raxium/vue/core",
    "exportName": "Icon",
    "category": "core",
    "description": "基于 Iconify 的通用图标组件，用于在按钮、表单、列表和状态提示中统一渲染图标。提供 theme 入口（tvIcon）与 class 样式覆写能力。不对应 Ark UI 官方组件，不支持 ui 配置，请使用 class 或 theme.crafts 覆写。",
    "basePrimitive": {
      "library": "@iconify/vue",
      "primitive": "Icon",
      "nativeElement": "svg"
    },
    "passThrough": {
      "htmlAttributes": ["aria-*", "data-*"],
      "notes": "组件不对应 Ark UI 官方组件，底层由 @iconify/vue Icon 渲染。不支持 ui，请使用 class 或 theme.crafts 覆写。"
    },
    "capabilities": [
      "theme",
      "class-override"
    ]
  },
  "contracts": {
    "props": [
      {
        "name": "icon",
        "required": true,
        "requiredSource": "type",
        "typeText": "string | IconifyIcon",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "object" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": false,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "图标标识或 Iconify 图标对象（必填）"
      },
      {
        "name": "class",
        "required": false,
        "requiredSource": "type",
        "typeText": "HTMLAttributes['class']",
        "typeSchema": {
          "anyOf": [
            { "type": "string" },
            { "type": "array" },
            { "type": "object" }
          ]
        },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "图标节点附加 class，用于颜色、动画、线宽等样式控制"
      },
      {
        "name": "theme",
        "required": false,
        "requiredSource": "type",
        "typeText": "Omit<ThemeCrafts<'tvIcon'>, 'size'>",
        "typeSchema": { "type": "object" },
        "default": null,
        "defaultKind": "implicit-undefined",
        "nullable": true,
        "passthrough": false,
        "deprecated": false,
        "dependsOn": [],
        "conflictsWith": [],
        "description": "主题与 crafts 覆写入口（IconProps 对 ThemeCrafts<'tvIcon'> 做了 Omit<'size'>，不提供 theme.size）"
      }
    ],
    "events": [],
    "slots": [],
    "themeConfiguration": {
      "fields": [
        {
          "name": "skin",
          "typeText": "'razer' | 'shadcn'",
          "typeSchema": { "enum": ["razer", "shadcn"] },
          "default": null,
          "defaultKind": "unknown",
          "description": "皮肤风格选择"
        },
        {
          "name": "surface",
          "typeText": "'light' | 'dark' | (string & {})",
          "typeSchema": { "type": "string" },
          "default": null,
          "defaultKind": "unknown",
          "description": "表面模式"
        },
        {
          "name": "bordered",
          "typeText": "boolean",
          "typeSchema": { "type": "boolean" },
          "default": null,
          "defaultKind": "unknown",
          "description": "是否启用边框语义"
        },
        {
          "name": "unstyled",
          "typeText": "boolean",
          "typeSchema": { "type": "boolean" },
          "default": null,
          "defaultKind": "unknown",
          "description": "是否移除内置样式"
        },
        {
          "name": "crafts",
          "typeText": "object | (() => tv)",
          "typeSchema": { "type": "object" },
          "default": null,
          "defaultKind": "unknown",
          "description": "覆写 tvIcon 或注入自定义 crafts"
        }
      ]
    },
    "uiConfiguration": {
      "fields": []
    }
  },
  "behaviorModel": {
    "stateVars": {},
    "derived": {},
    "transitions": []
  },
  "examples": [
    {
      "id": "basic",
      "mcp": {
        "server": "raxium",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Icon" },
        "exampleId": "basic"
      },
      "description": "基础用法"
    },
    {
      "id": "sizes",
      "mcp": {
        "server": "raxium",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Icon" },
        "exampleId": "sizes"
      },
      "description": "尺寸与排版联动"
    },
    {
      "id": "color-and-class",
      "mcp": {
        "server": "raxium",
        "tool": "get-example",
        "args": { "framework": "vue", "componentName": "Icon" },
        "exampleId": "color-and-class"
      },
      "description": "颜色与样式覆写"
    }
  ],
  "generationHints": {
    "preferredUsageOrder": ["icon", "class", "theme.crafts"],
    "safeDefaults": {},
    "a11yChecklist": [
      "图标来源统一使用 Iconify 命名空间（如 lucide:*）",
      "交互语义（点击、提示、可访问性）应由外层按钮/链接等承载"
    ],
    "codegenTemplates": {
      "minimal": "<Icon icon=\"lucide:check\" />",
      "withClass": "<Icon icon=\"lucide:check\" class=\"text-green-500\" />"
    },
    "antiPatterns": [
      "混用 lucide:check、heroicons:check、mdi:check 等不同命名空间",
      "<Icon icon=\"lucide:check\" @click=\"...\" /> 应包裹在 <button> 或 <a> 内"
    ]
  },
  "provenance": {
    "sources": [
      { "path": "./icon.doc.mdx", "kind": "doc" },
      { "path": "./props.ts", "kind": "type" },
      { "path": "./Icon.vue", "kind": "runtime" },
      { "path": "./icon.stories.ts", "kind": "story" }
    ],
    "precedence": ["runtime", "type", "doc"],
    "fieldSourceMap": {
      "contracts.props.icon.required": "type",
      "contracts.props.theme.typeText": "type",
      "contracts.themeConfiguration.omitSize": "doc",
      "contracts.uiConfiguration.fieldsEmpty": "doc"
    }
  }
}
