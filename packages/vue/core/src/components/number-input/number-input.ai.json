  "behaviorModel": {
    "stateVars": {
      "value": "string",
      "valueAsNumber": "number | null",
      "focused": "boolean"
    },
    "derived": {
      "showTriggerGroup": "showTrigger === true"
    },
    "transitions": [
      {
        "on": "increment",
        "guard": "!disabled",
        "effects": ["setValue(value+step)", "emit:update:modelValue", "emit:valueChange"]
      },
      {
        "on": "decrement",
        "guard": "!disabled",
        "effects": ["setValue(value-step)", "emit:update:modelValue", "emit:valueChange"]
      }
    ]
  },
