  "generationHints": {
    "preferredUsageOrder": ["modelValue/defaultValue", "min/max/step", "showTrigger", "theme"],
    "safeDefaults": {
      "showTrigger": false,
      "step": 1,
      "clampValueOnBlur": true
    },
    "a11yChecklist": [
      "范围明确的业务建议始终设置 min/max/step",
      "需要格式化显示时优先使用 locale + formatOptions"
    ],
    "codegenTemplates": {
      "minimal": "<NumberInput v-model=\"value\" />",
      "withTrigger": "<NumberInput v-model=\"value\" :show-trigger=\"true\" />"
    },
    "antiPatterns": [
      "<NumberInput v-model=\"qty\" /> — 在数量场景未设置 :min=\"0\" :max=\"99\" :step=\"1\" 导致非法值进入",
      "使用自定义 @update:modelValue 做 toFixed(2) — 应使用 formatOptions 保持输入态与展示态一致",
      "<NumberInput v-model=\"val\" :default-value=\"0\" /> — 同时使用 modelValue 与 defaultValue 导致冲突"
    ]
  },
