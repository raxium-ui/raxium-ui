      "controlled": "<Menu v-model:open=\"open\">\n  <MenuTrigger as-child><Button>Toggle</Button></MenuTrigger>\n  <MenuContent>\n    <MenuItem value=\"copy\"><MenuItemText>Copy</MenuItemText></MenuItem>\n  </MenuContent>\n</Menu>",
      "checkbox": "<Menu>\n  <MenuTrigger as-child><Button>Checkbox Menu</Button></MenuTrigger>\n  <MenuContent>\n    <MenuCheckboxItem v-for=\"v in items\" :key=\"v\" :value=\"v\" :checked=\"checked.includes(v)\" @update:checked=\"(val) => toggle(v, val)\">\n      <MenuItemText>{{ v }}</MenuItemText>\n    </MenuCheckboxItem>\n  </MenuContent>\n</Menu>",
      "radio": "<Menu>\n  <MenuTrigger as-child><Button>Radio Menu</Button></MenuTrigger>\n  <MenuContent>\n    <MenuRadioItemGroup v-model=\"selected\">\n      <MenuRadioItem v-for=\"v in items\" :key=\"v\" :value=\"v\">\n        <MenuItemText>{{ v }}</MenuItemText>\n      </MenuRadioItem>\n    </MenuRadioItemGroup>\n  </MenuContent>\n</Menu>",
      "submenu": "<Menu>\n  <MenuTrigger as-child><Button>Submenu</Button></MenuTrigger>\n  <MenuContent>\n    <MenuArrow />\n    <Menu :positioning=\"{ placement: 'right', offset: { mainAxis: 10 } }\">\n      <MenuTriggerItem value=\"sub1\">Submenu 1</MenuTriggerItem>\n      <Teleport to=\"body\">\n        <MenuContent>\n          <MenuItem value=\"a\"><MenuItemText>A</MenuItemText></MenuItem>\n        </MenuContent>\n      </Teleport>\n    </Menu>\n  </MenuContent>\n</Menu>",
      "context-trigger": "<Menu @select=\"selected = $event.value\">\n  <MenuContextTrigger as-child>\n    <div>Right click here</div>\n  </MenuContextTrigger>\n  <MenuContent>\n    <MenuItem v-for=\"v in items\" :key=\"v\" :value=\"v\">\n      <MenuItemText>{{ v }}</MenuItemText>\n    </MenuItem>\n  </MenuContent>\n</Menu>"
    },
