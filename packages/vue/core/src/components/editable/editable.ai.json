  "behaviorModel": {
    "stateVars": {
      "value": "string",
      "editing": "boolean",
      "empty": "boolean"
    },
    "derived": {
      "showInput": "editing === true",
      "showPreview": "editing === false"
    },
    "transitions": [
      {
        "on": "activation",
        "guard": "!disabled",
        "effects": ["setEditing(true)"]
      },
      {
        "on": "submit",
        "guard": "!disabled && !readOnly",
        "effects": ["setValue(inputValue)", "setEditing(false)", "emit:valueCommit"]
      },
      {
        "on": "cancel",
        "guard": "!disabled",
        "effects": ["setEditing(false)", "emit:valueRevert"]
      }
    ]
