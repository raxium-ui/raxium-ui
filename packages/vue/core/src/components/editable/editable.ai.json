        "maxLength",
        "aria-*",
        "data-*"
      ],
      "notes": "透传 Ark UI EditableRootBaseProps；theme、ui、clearable 为 Rark 扩展。"
    },
    "capabilities": [
      "v-model",
      "v-model:edit",
      "theme",
      "ui-override",
      "programmatic-api"
    ],
    "subComponents": ["EditableInput", "EditablePreview"]
