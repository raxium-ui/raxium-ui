      "controlled": "<Editable v-model=\"value\" v-model:edit=\"editing\" placeholder=\"Edit me\">\n  <EditableInput clearable />\n  <EditablePreview />\n</Editable>",
      "withControls": "<Editable activation-mode=\"none\" placeholder=\"Edit me\">\n  <EditableInput clearable />\n  <EditablePreview />\n  <template #suffix=\"{ editing }\">\n    <EditableControl>\n      <EditableEditTrigger v-if=\"!editing\" as-child><Button>Edit</Button></EditableEditTrigger>\n      <EditableSubmitTrigger v-if=\"editing\" as-child><Button>Submit</Button></EditableSubmitTrigger>\n      <EditableCancelTrigger v-if=\"editing\" as-child><Button>Cancel</Button></EditableCancelTrigger>\n    </EditableControl>\n  </template>\n</Editable>"
    },
